<!DOCTYPE html>
<html>
{{template "HtmlHead"}}
<body>
	{{template "Navigation" .}}
	
	<div class="container">
		<div class="hero">
			<h1>Plattentests.de <span class="emoji">💿</span><br>Highlights of the week</h1>
			<p>Discover the best music reviews and recommendations</p>
		</div>

		{{if .CreatePlaylistError}}
		<div class="status-message status-error" role="alert">
			<h2>Playlist Creation Failed</h2>
			<p>The website is up, but creating the playlist did not succeed.</p>
			<p class="error-reason">Reason: {{.CreatePlaylistError}}</p>
			<p>Please try again shortly.</p>
		</div>
		{{else}}

		<div class="spotify-embed">
			<iframe style="border-radius:12px" src="https://open.spotify.com/embed/playlist/{{ .Records.PlaylistID }}?utm_source=generator&theme=0" width="100%" height="600" frameBorder="0" allowfullscreen="" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy" title="Spotify playlist embed"></iframe>
		</div>

		<div class="status-message" role="status">
			<h2>Run summary</h2>
			<p>Search success: <strong>{{.Records.FoundTracks}} / {{.Records.TotalTracks}}</strong> tracks ({{printf "%.1f" .Records.SearchSuccessRate}}%).</p>
			<p>Not found: <strong>{{len .Records.NotFound}}</strong> track(s).</p>
			{{if .Records.ComparedToProd}}
			<p>Compared to production playlist: <strong>{{.Records.NewTracksComparedToProd}}</strong> new track(s), <strong>{{.Records.AlreadyInProdTracks}}</strong> already in production.</p>
			{{end}}
		</div>

		{{template "RecordTable" .Records}}
		
		{{if .Records.NotFound}}
		<div class="not-found">
			<h3>Not Found</h3>
			<ul>
				{{range .Records.NotFound}}
				<li>{{.}}</li>
				{{end}}
			</ul>
		</div>
		{{end}}
		{{end}}
	</div>

	{{template "Footer" .}}

	{{template "FormatTableScript"}}
</body>
</html>
