{{define "HtmlHead"}}
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<meta name="theme-color" content="#cc0000">
	<link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
	<link rel="icon" type="image/x-icon" href="/favicon.ico">
	<link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png">
	<link rel="manifest" href="/manifest.json">
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="/assets/css/modern.css">
	<link rel="stylesheet" href="/assets/css/style.css">

	<title>Plattentests.de 💿 - Highlights of the week</title>
</head>
{{end}}

{{define "Navigation"}}
	<header>
		<div class="container">
			<nav>
				<a href="/" aria-label="Highlights view"><span class="emoji">💿</span> Highlights</a>
				<a href="/playlist" aria-label="Playlist view"><span class="emoji">🎧</span> Playlist</a>
				<a href="/search" aria-label="Search view"><span class="emoji">🔍</span> Search</a>
				{{if .IsAuthenticated}}
					<a href="/createPlaylist" aria-label="Test view"><span class="emoji">🔈</span> Test</a>
					<a href="/createPlaylist?playlist=prod" aria-label="Production view"><span class="emoji">🔊</span> Prod</a>
				{{else}}
					<a href="{{.LoginURL}}" aria-label="Login view"><span class="emoji">🔐</span> Login</a>
				{{end}}
			</nav>
			<div class="header-title" id="header-title">
				<span>Plattentests.de 💿</span>
			</div>
		</div>
	</header>
{{end}}

{{define "RecordTable"}}
	<!-- Modern Cards Grid -->
	<div class="records-grid">
		{{range .Records}}
			<div class="record-card{{if .IsRecordOfTheWeek}} record-of-the-week{{end}}" data-imageurl="{{.Image}}" data-score="{{.Score}}" data-sort-title="{{.Band}} {{.Recordname}}" data-record-of-week="{{.IsRecordOfTheWeek}}">
				<div class="record-card-inner{{if .Description}} record-card-flippable{{end}}">
					<div class="record-face record-face-front">
						<div class="record-image">
							<a href="{{.Link}}">
								<img src="{{.Image}}" alt="Cover art for {{.Band}} – {{.Recordname}}" loading="lazy">
							</a>
							<div class="record-score"><span class="emoji">💿</span> {{.Score}}/10</div>
						</div>
						<div class="record-content">
							<div class="record-band">{{.Band}}</div>
							<div class="record-title">{{.Recordname}}</div>
							{{if .ReleaseDate}}
								<div><span class="emoji">📅</span> {{.ReleaseDate}}{{if .HasFutureReleaseDate}} <span class="emoji">⏭️</span>{{end}}</div>
							{{end}}
							<ul class="record-tracks">
								{{range .Tracks}}
									<li>
									{{ if .Tracklink }}
										<span class="emoji">🎵</span> <a href="{{ .Tracklink}}">{{.Trackname}}</a> 
									{{ else }}
										<span class="emoji">🔍</span> {{.Trackname}} 
									{{end}}
									</li>
								{{end}}
							</ul>
							{{if .Description}}
							<div class="record-description-trigger-wrap">
								<button class="record-description-toggle" type="button" aria-expanded="false">
									<span class="emoji">📖</span> Read review
								</button>
							</div>
							{{end}}
						</div>
					</div>
					{{if .Description}}
					<div class="record-face record-face-back" aria-hidden="true">
						<div class="record-review-content">
							<div class="record-review-header">
								<div>
									<div class="record-band">{{.Band}}</div>
									<div class="record-title">{{.Recordname}}</div>
								</div>
								<button class="record-description-close" type="button">Back to tracks</button>
							</div>
							{{if .Headline}}<h4 class="review-headline">{{.Headline}}</h4>{{end}}
							<p>{{.Description}}</p>
						</div>
					</div>
					{{end}}
				</div>
			</div>
		{{end}}
	</div>

	<!-- Fallback Table (hidden by default) -->
	<table class="recordTable">
		<thead>
			<tr>
				<th>Image</th>
				<th>Band & Record</th>
				<th>Highlights</th>
			</tr>
		</thead>
		<tbody>
			{{range .Records}}
				<tr data-imageurl="{{.Image}}">
					<td><a href="{{.Link}}"><img src="{{.Image}}" alt="{{.Band}}"></a></td>
					<td>{{.Band}}<br>
						<strong>{{.Recordname}}</strong><br>
						{{if .ReleaseDate}}<span class="emoji">📅</span> {{.ReleaseDate}}{{if .HasFutureReleaseDate}} <span class="emoji">⏭️</span>{{end}}<br>{{end}}
						<span class="emoji">💿</span> {{.Score}}/10
					</td>
					<td>
						<ul>
						{{range .Tracks}}
							<li>
							{{ if .Tracklink }}
								<span class="emoji">🎵</span> <a href="{{ .Tracklink}}">{{.Trackname}}</a> 
							{{ else }}
								<span class="emoji">🔍</span> {{.Trackname}} 
							{{end}}
							</li>
						{{end}}
						</ul>
					</td>
				</tr>
			{{end}}
		</tbody>
	</table>
{{end}}


{{define "Footer"}}
	<footer>
		<div class="container">
			<p>Coded with <span class="emoji">❤️</span> by <a href="https://github.com/jetzlstorfer">jetzlstorfer</a><br>Source on <a href="https://github.com/jetzlstorfer/plattentests-go">GitHub</a>. Content crawled from <a href="https://plattentests.de">Plattentests.de</a>.</p>
			<p>{{if .GitInfo}} 
					<a href="https://github.com/jetzlstorfer/plattentests-go/commit/{{.GitInfo}}"><img alt="GitHub last commit (branch)" src="https://img.shields.io/github/last-commit/jetzlstorfer/plattentests-go?branch=main"></a> 
				{{else}} 
					<img alt="GitHub last commit (branch)" src="https://img.shields.io/github/last-commit/jetzlstorfer/plattentests-go?branch=main">
	 			{{end}}
	 		</p>
		</div>
	</footer>
{{end}}

{{define "FormatTableScript" }}
<script>
function handleHeaderTitle() {
    const headerTitle = document.getElementById('header-title');
    const heroSection = document.querySelector('.hero');
    
    if (!headerTitle || !heroSection) return;
    
    const observer = new IntersectionObserver(
        (entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    // Hero is visible, hide header title
                    headerTitle.classList.remove('visible');
                } else {
                    // Hero is not visible, show header title
                    headerTitle.classList.add('visible');
                }
            });
        },
        {
            threshold: 0.1,
            rootMargin: '0px 0px -50px 0px'
        }
    );
    
    observer.observe(heroSection);
}

// Add some modern interactions
document.addEventListener('DOMContentLoaded', function() {
    // Initialize header title scroll functionality
    handleHeaderTitle();
    
    // Smooth scroll for navigation links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            document.querySelector(this.getAttribute('href')).scrollIntoView({
                behavior: 'smooth'
            });
        });
    });
    
    // Add loading class removal after cards are loaded
    setTimeout(function() {
        document.querySelectorAll('.record-card').forEach(function(card) {
            card.classList.remove('loading');
        });
    }, 100);

    // --- Grid layout toggle ---
    const grid = document.querySelector('.records-grid');

    function setGridCols(cols) {
        if (!grid) return;
        grid.className = grid.className.replace(/\bgrid-\d+\b/g, '').trim();
        grid.classList.add('grid-' + cols);
        document.querySelectorAll('.grid-btn').forEach(function(btn) {
            btn.classList.toggle('active', btn.dataset.cols === String(cols));
        });
        localStorage.setItem('gridCols', cols);
    }

    document.querySelectorAll('.grid-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            setGridCols(this.dataset.cols);
        });
    });

    // Restore saved grid preference (default: 3)
    setGridCols(localStorage.getItem('gridCols') || '3');

    // --- Client-side sort ---
    function sortRecords(by) {
        if (!grid) return;
        const cards = Array.from(grid.querySelectorAll('.record-card'));
        cards.sort(function(a, b) {
            if (by === 'title') {
                return (a.dataset.sortTitle || '').localeCompare(b.dataset.sortTitle || '', undefined, { sensitivity: 'base' });
            }
            // score descending (default), record of the week always on top
            const aIsRotw = a.dataset.recordOfWeek === 'true';
            const bIsRotw = b.dataset.recordOfWeek === 'true';
            if (aIsRotw) return -1;
            if (bIsRotw) return 1;
            return parseInt(b.dataset.score || '0', 10) - parseInt(a.dataset.score || '0', 10);
        });
        cards.forEach(function(card) { grid.appendChild(card); });
        document.querySelectorAll('.sort-btn').forEach(function(btn) {
            btn.classList.toggle('active', btn.dataset.sort === by);
        });
        localStorage.setItem('sortBy', by);
    }

    document.querySelectorAll('.sort-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            sortRecords(this.dataset.sort);
        });
    });

    // Restore saved sort preference (default: score)
    sortRecords(localStorage.getItem('sortBy') || 'score');

	// --- Flip card reviews ---
	function updateReviewCardHeights() {
		document.querySelectorAll('.record-card .record-card-flippable').forEach(function(inner) {
			const front = inner.querySelector('.record-face-front');
			if (!front) return;
			inner.style.setProperty('--record-card-height', front.offsetHeight + 'px');
		});
	}

	function setReviewOpen(inner, isOpen) {
		const card = inner.closest('.record-card');
		const front = inner.querySelector('.record-face-front');
		const back = inner.querySelector('.record-face-back');
		const toggle = inner.querySelector('.record-description-toggle');

		if (!card || !front || !back) return;

		card.classList.toggle('review-open', isOpen);
		if (toggle) {
			toggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
		}
		front.setAttribute('aria-hidden', isOpen ? 'true' : 'false');
		back.setAttribute('aria-hidden', isOpen ? 'false' : 'true');

		if (!isOpen) {
			const reviewContent = back.querySelector('.record-review-content');
			if (reviewContent) {
				reviewContent.scrollTop = 0;
			}
		}
	}

	document.querySelectorAll('.record-description-toggle').forEach(function(button) {
		button.addEventListener('click', function() {
			const inner = this.closest('.record-card-inner');
			if (!inner) return;
			setReviewOpen(inner, true);
		});
	});

	document.querySelectorAll('.record-description-close').forEach(function(button) {
		button.addEventListener('click', function() {
			const inner = this.closest('.record-card-inner');
			if (!inner) return;
			setReviewOpen(inner, false);
		});
	});

	document.querySelectorAll('.record-card .record-card-flippable').forEach(function(inner) {
		inner.addEventListener('click', function(event) {
			const card = inner.closest('.record-card');
			if (!card || !card.classList.contains('review-open')) return;
			if (event.target.closest('a, button')) return;
			setReviewOpen(inner, false);
		});
	});

	updateReviewCardHeights();
	window.addEventListener('resize', updateReviewCardHeights);

});
</script>
{{end}}

{{define "ErrorPage"}}
<!DOCTYPE html>
<html>
{{template "HtmlHead"}}
<body>
	{{template "Navigation" .}}
	<div class="container">
		<div class="hero">
			<h1><span class="emoji">⚠️</span> Something went wrong</h1>
			<p>Could not load the records of the week. Please try again later.</p>
		</div>
		<div style="margin-top: 2rem;">
			<a href="/" class="control-btn">Try again</a>
		</div>
	</div>
</body>
</html>
{{end}}
